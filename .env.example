# GitHub Pages: set VITE_BASE=/your-repo-name/ for project pages, or / for user site
VITE_BASE=/

# Firebase (from Firebase Console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Voice food: OpenRouter (required for parsing speech → food items). Embedded in client bundle.
VITE_OPENROUTER_API_KEY=

# Calorie lookup: either mock (no CalorieNinjas) or real API key — not both required.
# Mock: deterministic fake calories for local/demo (no external nutrition HTTP).
VITE_MOCK_CALORIE_API=false
# Real: https://calorieninjas.com — only used when VITE_MOCK_CALORIE_API is not true/1.
VITE_CALORIENINJAS_API_KEY=
